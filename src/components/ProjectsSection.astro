---
import { getCollection } from 'astro:content';
import Card from './Card.astro';

const projects = await getCollection("projects");
---

<section id="projects">
  <div id="projects-sidebar">
    <Card title="My Projects">
      <p>
        Here's a sneak peek into some of my open source projects that I've
        built! I have a strong interest in systems programming and programming
        language theory.
      </p>
    </Card>
  </div>
  <div id="projects-list">
    {
      projects
        .filter(({ data: { show } }) => show)
        .map(({ data }) => (
          <Card disableTitlebar>
            <h1 id="project-title">
              <a id="project-link" href={data.url} target="_blank" rel="noopener noreferrer">
                {data.name}
              </a>
            </h1>
            <ul id="list">
              {data.description.map((des) => <li>{des}</li>)}
            </ul>
            <div id="project-tags">
              {data.tags.map((tag) => <p id="project-tag">{tag}</p>)}
            </div>
          </Card>
        ))
    }
  </div>
</section>

<style lang="scss">
@use '../styles/mixins' as *;

#projects {
  display: grid;
  grid-template-columns: 1fr;
  min-height: 100vh;
  max-width: 50rem;
  margin: 0 auto;

  @media (min-width: 1280px) {
    grid-template-columns: 1fr 3fr;
  }

  #projects-sidebar {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    max-height: 100vh;
    top: 0;

    padding-top: 3rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;

    @media (min-width: 640px) {
      padding-left: 2rem;
      padding-right: 2rem;
    }

    @media (min-width: 1280px) {
      position: sticky;
      padding-top: 3rem;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }
  }

  #projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    padding-top: 1rem;
    padding-bottom: 5rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;

    @media (min-width: 640px) {
      padding-left: 2rem;
      padding-right: 2rem;
    }

    @media (min-width: 1280px) {
      position: sticky;
      padding-top: 3rem;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    #project-title {
      margin-bottom: 0.5rem;
    }

    #project-link {
      color: var(--teal-600);
    }

    #project-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;

      #project-tag {
        @include font-size(sm);
        border: 2px solid black;
        border-radius: var(--rounded);
        padding: 0.25rem 0.5rem;
        background-color: var(--teal-400);
      }
    }
  }

  @media (min-width: 1280px) {
    grid-template-columns: 1fr 3fr;
    max-width: 75rem;
  }
}
</style>
