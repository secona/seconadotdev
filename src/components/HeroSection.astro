---
import Card from './Card.astro';
---

<section id="hero">
  <div id="container">
    <Card title="Hello, World!">
      <p>My name is</p>
      <h1 id="name">Vito Secona</h1>
      <p id="role-sr" class="sr-only">Software Engineer, Compiler Engineer</p>
      <p aria-hidden="true">
        <span id="role-text">Software Engineer</span><span id="cursor">|</span>
      </p>
    </Card>
    <div id="hero-buttons">
      <a href="#projects" class="hero-btn">Learn More</a>
      <a href="#contacts" class="hero-btn">Contact Me</a>
    </div>
  </div>
</section>

<script>
  const roles = ["Software Engineer", "Compiler Engineer"];
  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function typeEffect() {
    const element = document.getElementById("role-text");
    if (!element) return;

    const currentRole = roles[roleIndex];

    if (isDeleting) {
      element.textContent = currentRole.substring(0, charIndex - 1);
      charIndex--;
    } else {
      element.textContent = currentRole.substring(0, charIndex + 1);
      charIndex++;
    }

    if (!isDeleting && charIndex === currentRole.length) {
      isDeleting = true;
      setTimeout(typeEffect, 2000);
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      roleIndex = (roleIndex + 1) % roles.length;
      setTimeout(typeEffect, 500);
    } else {
      const speed = isDeleting ? 50 : 100;
      setTimeout(typeEffect, speed);
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    setTimeout(typeEffect, 1000);
  });
</script>

<style lang="scss">
@use '../styles/mixins' as *;

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

#hero {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  padding: 0 1rem;

  @media (min-width: 640px) {
    padding: 0 2rem;
  }

  @media (min-width: 768px) {
    padding: 0 4rem;
  }

  @media (min-width: 1280px) {
    padding: 0 6rem;
  }

  #container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 36rem;
  }

  #name {
    @media (min-width: 640px) {
      @include font-size(5xl);
    }

    @media (max-width: 640px) {
      @include font-size(3xl);
    }
  }

  #cursor {
    animation: blink 0.7s steps(1) infinite;
    margin-left: 2px;
  }

  #role-text {
    white-space: nowrap;
  }

  #hero-buttons {
    display: flex;
    gap: 0.75rem;
    width: 100%;

    @media (max-width: 400px) {
      flex-direction: column;
    }
  }

  .hero-btn {
    flex: 1;
    padding: 0.5rem 1.25rem;
    border: 2px solid black;
    border-radius: var(--rounded);
    box-shadow: var(--hard-shadow);
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    transition: all 0.2s ease;

    &:hover {
      transform: translate(-3px, -3px);
    }

    &:first-child {
      background-color: var(--teal-400);
    }

    &:last-child {
      background-color: white;
    }
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
}
</style>
