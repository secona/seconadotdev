---
import { BookOpenIcon, RssIcon } from 'astro-feather';
import { getCollection } from "astro:content";
import NavbarLayout from "../../layouts/NavbarLayout.astro";
import Card from "../../components/Card.astro";

const blogs = await getCollection("blogs");
const sortedBlogs = blogs
  .filter((blog) => blog.data.show)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const allTags = [...new Set(sortedBlogs.flatMap(blog => blog.data.tags))].sort();

function getExcerpt(body: string, maxLength = 200): string {
  return body
    .replace(/^#+\s+.*$/gm, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]*)\]\(.*?\)/g, '$1')
    .replace(/[*_~`]{1,3}/g, '')
    .replace(/^>\s+/gm, '')
    .replace(/<[^>]*>/g, '')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, maxLength);
}

function estimateMinutesRead(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}
---

<NavbarLayout pageTitle="Vito Secona's Blog">
  <main>
    <div class="blogs-sidebar">
      <Card title="My Blog" noHover>
        <Fragment slot="titlebar">
          <h1><BookOpenIcon size={16} /> My Blog</h1>
          <span>ooo</span>
        </Fragment>
        <p>
          Here are some of my blogs! I mostly write about Rust and my journey
          in the software engineering world. Feel free to explore my thoughts
          on programming, systems development, and technology.
        </p>
        <!-- <div class="blogs-stats">
          <p class="stats-text">
            <strong>{sortedBlogs.length}</strong> {blogs.length === 1 ? 'post' : 'posts'} published
          </p>
        </div> -->
        <a href="/rss.xml" class="rss-link" aria-label="RSS Feed">
          <RssIcon size={16} /> RSS Feed
        </a>
      </Card>

      <div class="blogs-filter">
        <!-- <input type="text" id="title-filter" placeholder="Search titles..." /> -->
        <select id="tag-select">
          <option value="">All Tags</option>
          {allTags.map(tag => (
            <option value={tag}>#{tag}</option>
          ))}
        </select>
        <!-- <button id="clear-filters">Clear</button> -->
      </div>
    </div>
    <div class="blogs-list">
      {
        sortedBlogs.map((blog) => (
          <div class="blog-card" data-tags={JSON.stringify(blog.data.tags)}>
            <Card disableTitlebar noHover>
              <div class="entry">
                <h1 class="entry-title">
                  <a href={`/blog/${blog.id}`}>
                    {blog.data.title}
                  </a>
                </h1>
                <div class="entry-metadata">
                  <time>
                    {new Date(blog.data.publishedAt).toLocaleDateString("en-US", {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                  &mdash; {estimateMinutesRead(blog.body ?? '')} min read
                  {blog.data.tags.map((tag) => (
                    <span> &mdash; <a href={`/blog?tag=${tag}`} class="entry-tag">#{tag}</a></span>
                  ))}
                </div>
                {blog.body && (
                  <p class="entry-description">{getExcerpt(blog.body)}&hellip;</p>
                )}
              </div>
            </Card>
          </div>
        ))
      }
    </div>
  </main>
</NavbarLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const select = document.getElementById('tag-select') as HTMLSelectElement;
    const blogCards = document.querySelectorAll('.blog-card');

    function updateUrl(tag: string) {
      const params = new URLSearchParams();
      if (tag) params.set('tag', tag);
      const newUrl = params.toString() ? `?${params.toString()}` : window.location.pathname;
      window.history.replaceState({ path: newUrl }, '', newUrl);
    }

    function filterBlogs() {
      const tag = select ? select.value : '';

      blogCards.forEach((card) => {
        const tags = JSON.parse((card as HTMLElement).dataset.tags || '[]');
        const matchesTag = !tag || tags.includes(tag);
        (card as HTMLElement).style.display = matchesTag ? 'block' : 'none';
      });
    }

    // Initialize from URL
    const urlParams = new URLSearchParams(window.location.search);
    const tag = urlParams.get('tag') || '';
    if (select) select.value = tag;
    filterBlogs();

    // Handle select change
    if (select) {
      select.addEventListener('change', () => {
        updateUrl(select.value);
        filterBlogs();
      });
    }
  });
</script>

<style lang="scss">
@use '../../styles/mixins' as *;

main {
  display: grid;
  grid-template-columns: 1fr;
  min-height: 100vh;
  max-width: 50rem;
  margin: 0 auto;

  @media (min-width: 1280px) {
    grid-template-columns: 1fr 3fr;
    max-width: 75rem;
  }

  .blogs-sidebar {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0.5rem;
    max-height: 100vh;
    top: 0;

    padding-top: 5rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;

    @media (min-width: 640px) {
      padding-left: 2rem;
      padding-right: 2rem;
    }

    @media (min-width: 1280px) {
      position: sticky;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    .blogs-stats {
      margin-top: 1.5rem;
      padding-top: 1rem;
      border-top: 1px solid var(--gray-400);

      .stats-text {
        @include font-size(sm);
      }
    }

    .blogs-filter {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;

      input, select {
        width: 100%;
        padding: 0.5rem;
        border: 2px solid black;
        border-radius: var(--rounded, 8px);
        background-color: white;
        font-family: inherit;
        box-shadow: 2px 2px 0 0 black;
        box-sizing: border-box;

        &:focus {
          outline: none;
          box-shadow: 1px 1px 0 0 black;
          transform: translate(1px, 1px);
        }
      }

      select {
        cursor: pointer;
      }

      button {
        width: fit-content;
        padding: 0.5rem 1rem;
        border: 2px solid black;
        border-radius: var(--rounded, 8px);
        background-color: var(--red-400);
        color: white;
        font-family: inherit;
        font-weight: 500;
        cursor: pointer;
        box-shadow: 2px 2px 0 0 black;

        &:hover {
          background-color: var(--red-500);
        }

        &:active {
          box-shadow: 1px 1px 0 0 black;
          transform: translate(1px, 1px);
        }
      }
    }

    .rss-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--teal-600);
      font-weight: 600;
      font-size: 0.875rem;
      text-decoration: underline;

      margin-top: 1rem;
    }
  }

  .blogs-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    padding-top: 5rem;
    padding-bottom: 5rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;

    @media (min-width: 640px) {
      padding-left: 2rem;
      padding-right: 2rem;
    }

    @media (min-width: 1280px) {
      position: sticky;
      padding-top: 5rem;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    .entry {
      .entry-title {
        @include font-size(xl);
        margin-bottom: 0.25rem;

        a {
          color: var(--teal-600);
          font-weight: 600;
        }
      }

      .entry-metadata {
        @include font-size(sm);
        color: var(--gray-500);
      }

      .entry-description {
        @include font-size(sm);
        color: var(--gray-700);
        margin-top: 0.75rem;
        line-height: 1.5;
      }
    }
  }
}
</style>
