---
import { getCollection } from 'astro:content';
import { ExternalLinkIcon, GithubIcon, LinkedinIcon, TwitterIcon } from 'astro-feather';
import NavbarLayout from '../layouts/NavbarLayout.astro';
import BlueskyIcon from '../components/BlueskyIcon.astro';
import Card from '../components/Card.astro';

const experiences = await getCollection("experiences");
const projects = await getCollection("projects");
---

<NavbarLayout>
  <section id="hero">
    <div id="container">
      <Card title="Hello, World!">
        <p>My name is</p>
        <h1 id="name">Vito Secona</h1>
        <p id="role-sr" class="sr-only">Software Engineer, Compiler Engineer</p>
        <p aria-hidden="true">
          <span id="role-text">Software Engineer</span><span id="cursor">|</span>
        </p>
      </Card>
      <div id="hero-buttons">
        <a href="#projects" class="hero-btn">Learn More</a>
        <a href="#contacts" class="hero-btn">Contact Me</a>
      </div>
    </div>
  </section>

  <section id="introduction">
    <div id="container">
      <Card title="Introduction">
        <p>
          Hello, everyone! My name is Vito. I am a final-year undergraduate student at
          Universitas Indonesia with a strong interest in compilers.
        </p>
        <br />
        <p>
          In my free time, I contribute to <a href="https://github.com/llvm/llvm-project/pulls?q=is%3Apr+author%3Asecona">The LLVM Project</a>,
          mainly the MLIR subproject. I also have a compiler project named
          <a href="https://github.com/belalang-project/belalang">Belalang</a>, which
          uses LLVM technologies.
        </p>
      </Card>
      <a id="cv-link" href="/secona-cv.pdf" target="_blank" rel="noopener noreferrer">
        <span>My CV</span> <ExternalLinkIcon />
      </a>
    </div>
  </section>

  <section id="experiences">
    <div id="experiences-sidebar">
      <Card title="My Experiences">
        Here's a sneak peek into my journey! I've been involved in many
        student-led organization and events. Beyond that, I've played a role in
        education as a teaching assistant for some CS courses at campus.
      </Card>
    </div>
    <div id="experiences-list">
      {
        experiences
          .filter(({ data: { show } }) => show)
          .map(({ data: { startDate, endDate, title, description, employer, employerUrl }}) => (
            <Card disableTitlebar>
              <h1>{title} @ <a id="at" target="_blank" rel="noopener noreferrer" href={employerUrl}>{employer}</a></h1>
              <p id="duration">{startDate} - {endDate}</p>
              <ul id="list">
                {description.map((des) => <li>{des}</li>)}
              </ul>
            </Card>
          ))
      }
    </div>
  </section>

  <section id="projects">
    <div id="projects-sidebar">
      <Card title="My Projects">
        <p>
          Here's a sneak peek into some of my open source projects that I've
          built! I have a strong interest in systems programming and programming
          language theory.
        </p>
      </Card>
    </div>
    <div id="projects-list">
      {
        projects
          .filter(({ data: { show } }) => show)
          .map(({ data }) => (
            <Card disableTitlebar>
              <h1 id="project-title">
                <a id="project-link" href={data.url} target="_blank" rel="noopener noreferrer">
                  {data.name}
                </a>
              </h1>
              <ul id="list">
                {data.description.map((des) => <li>{des}</li>)}
              </ul>
              <div id="project-tags">
                {data.tags.map((tag) => <p id="project-tag">{tag}</p>)}
              </div>
            </Card>
          ))
      }
    </div>
  </section>

  <section id="contacts">
    <div id="container">
      <Card title="My Socials">
        <p id="contacts-greetings">
          Let's connect! You can find me on these platforms, but I am most active
          on my Twitter (X) account where I share insights on tech, my projects,
          and what I'm currently working on. Feel free to reach out!
        </p>
      </Card>
      <div id="contacts-links">
        <a class="contact-link github" href="https://github.com/secona" target="_blank" rel="noopener noreferrer" >
          <GithubIcon />
          <p>@secona</p>
        </a>
        <a class="contact-link linkedin" href="https://linkedin.com/in/secona" target="_blank" rel="noopener noreferrer">
          <LinkedinIcon />
          <p>@secona</p>
        </a>
        <a class="contact-link twitter" href="https://x.com/secona0" target="_blank" rel="noopener noreferrer">
          <TwitterIcon />
          <p>@secona0</p>
        </a>
        <a class="contact-link bsky" href="https://bsky.app/profile/secona.dev" target="_blank" rel="noopener noreferrer">
          <BlueskyIcon />
          <p>@secona.dev</p>
        </a>
      </div>
    </div>
  </section>
</NavbarLayout>

<script>
  const roles = ["Software Engineer", "Compiler Engineer"];
  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function typeEffect() {
    const element = document.getElementById("role-text");
    if (!element) return;

    const currentRole = roles[roleIndex];

    if (isDeleting) {
      element.textContent = currentRole.substring(0, charIndex - 1);
      charIndex--;
    } else {
      element.textContent = currentRole.substring(0, charIndex + 1);
      charIndex++;
    }

    if (!isDeleting && charIndex === currentRole.length) {
      isDeleting = true;
      setTimeout(typeEffect, 2000);
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      roleIndex = (roleIndex + 1) % roles.length;
      setTimeout(typeEffect, 500);
    } else {
      const speed = isDeleting ? 50 : 100;
      setTimeout(typeEffect, speed);
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    setTimeout(typeEffect, 1000);
  });
</script>

<style lang="scss">
@use '../styles/mixins' as *;

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

#hero {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  padding: 0 1rem;

  #container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  #name {
    @media (min-width: 640px) {
      @include font-size(5xl);
    }

    @media (max-width: 640px) {
      @include font-size(3xl);
    }
  }

  #cursor {
    animation: blink 0.7s steps(1) infinite;
    margin-left: 2px;
  }

  #hero-buttons {
    display: flex;
    gap: 0.75rem;
    width: 100%;
  }

  .hero-btn {
    flex: 1;
    padding: 0.5rem 1.25rem;
    border: 2px solid black;
    border-radius: var(--rounded);
    box-shadow: var(--hard-shadow);
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    transition: transform 0.2s ease;

    &:hover {
      transform: translate(-3px, -3px);
    }

    &:first-child {
      background-color: var(--orange-400);
    }

    &:last-child {
      background-color: white;
    }
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
}

#introduction {
  display: grid;
  grid-template-columns: 1fr;
  place-items: center;

  #container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    justify-content: center;
    align-items: flex-end;
    max-width: 48rem;
  }

  #cv-link {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;

    background-color: white;
    box-shadow: var(--hard-shadow);
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s ease;

    border-width: 2px;
    border-color: black;
    border-radius: var(--rounded);

    &:hover {
      transform: translate(-3px, -3px);
    }
  }

  & > * {
    padding-top: 5rem;
    padding-bottom: 5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;

    @media (min-width: 1280px) {
      padding-top: 6rem;
      padding-bottom: 6rem;
      padding-left: 5rem;
      padding-right: 5rem;
    }
    @media (min-width: 640px) {
      padding-left: 4rem;
      padding-right: 4rem;
    }
    @media (min-width: 768px) {
      padding-left: 7rem;
      padding-right: 7rem;
    }
  }
}

#experiences {
  display: grid;
  grid-template-columns: 1fr;
  min-height: 100vh;

  #experiences-sidebar {
    background-color: var(--blue-300);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    max-height: 100vh;
    top: 0;

    border-bottom-width: 2px;
    border-top-width: 2px;
    border-style: solid;
    border-color: black;

    @media (max-width: 1280px) {
      border-right: none;
    }

    @media (min-width: 1280px) {
      position: sticky;
      border-right: 2px solid black;
    }
  }

  #experiences-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    #duration {
      color: var(--gray-500);
      @include font-size(sm);
    }

    #at {
      color: var(--blue-600);

      &:hover {
        text-decoration: underline;
      }
    }
  }

  & > * {
    padding-top: 5rem;
    padding-bottom: 5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;

    &:not(:last-child) {
      border-inline-start-width: 0px;
      border-inline-end-width: 2px;
      border-color: black;
    }

    @media (min-width: 1280px) {
      padding-top: 6rem;
      padding-bottom: 6rem;
      padding-left: 5rem;
      padding-right: 5rem;
    }
    @media (min-width: 640px) {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  @media (min-width: 1280px) {
    grid-template-columns: 1fr 2fr;
  }
}

#projects {
  display: grid;
  grid-template-columns: 1fr;
  min-height: 100vh;

  @media (min-width: 1280px) {
    grid-template-columns: 1fr 2fr;
  }

  #projects-sidebar {
    background-color: var(--red-300);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    max-height: 100vh;
    top: 0;

    border-bottom-width: 2px;
    border-style: solid;
    border-color: black;

    @media (max-width: 1280px) {
      border-top: 2px solid black;
      border-right: none;
    }

    @media (min-width: 1280px) {
      position: sticky;
      border-right: 2px solid black;
    }
  }

  #projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    #project-title {
      margin-bottom: 0.5rem;
    }

    #project-link {
      color: var(--blue-600);

      &:hover {
        text-decoration: underline;
      }
    }

    #project-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;

      #project-tag {
        @include font-size(sm);
        border: 2px solid black;
        border-radius: var(--rounded);
        padding: 0.25rem 0.5rem;
        background-color: var(--red-300);
      }
    }
  }

  & > * {
    padding-top: 5rem;
    padding-bottom: 5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;

    &:not(:last-child) {
      border-inline-start-width: 0px;
      border-inline-end-width: 2px;
      border-color: black;
    }

    @media (min-width: 1280px) {
      padding-top: 6rem;
      padding-bottom: 6rem;
      padding-left: 5rem;
      padding-right: 5rem;
    }
    @media (min-width: 640px) {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }
}

#contacts {
  min-height: 100vh;
  display: grid;
  place-items: center;
  background-color: transparent;
  padding: 0 1.5rem;

  #container {
    display: flex;
    gap: 1.5rem;

    @media (min-width: 768px) {
      flex-direction: row;
      align-items: start;
    }

    @media (max-width: 768px) {
      align-items: stretch;
      flex-direction: column;
    }

    #contacts-greetings {
      max-width: 24rem;
    }

    #contacts-links {
      display: flex;
      flex-direction: column;

      @media (min-width: 768px) {
        gap: 1rem;
      }

      @media (max-width: 768px) {
        gap: 0.5rem;
      }

      .contact-link {
        display: flex;
        flex-direction: row;
        gap: 1rem;
        color: white;

        border-width: 2px;
        border-color: black;
        border-radius: var(--rounded);

        padding: 0.5rem 1.5rem;

        box-shadow: var(--hard-shadow);

        &.github { background-color: #333333; }
        &.linkedin { background-color: #0077b5; }
        &.twitter { background-color: #1DA1F2; }
        &.bsky { background-color: #0085ff; }
      }
    }
  }
}
</style>
